{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "Oxi",
  "version": "0.1.0",
  "identifier": "com.oxi.desktop",
  "build": {
    "beforeBuildCommand": "node oxi-desktop/assemble-dist.mjs",
    "frontendDist": "../../dist-desktop",
    "devUrl": "http://localhost:8080/web/"
  },
  "app": {
    "windows": [
      {
        "title": "Oxi",
        "width": 1280,
        "height": 900,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/Ryujiyasu/oxi/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDgyNjgwQ0I0MzNEMDBGQ0IKUldUTEQ5QXp0QXhvZ25tTHBMeUNtaFllK1VxbXhINit3dlJUMEVncnlnNmgzOEFJYU53YjZlTEIK",
      "windows": {
        "installMode": "passive"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "windows": {
      "wix": {
        "language": ["en-US", "ja-JP"]
      },
      "nsis": {
        "languages": ["English", "Japanese"],
        "displayLanguageSelector": true
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "linux": {
      "deb": {
        "depends": ["libwebkit2gtk-4.1-dev", "libgtk-3-0"]
      }
    }
  }
}
